# Exclude everything — the Docker image only needs the pre-built fat JAR.
# Build the JAR first: ./gradlew :cli:shadowJar
**

# Allow only the fat JAR produced by the Shadow plugin.
!cli/build/libs/
!cli/build/libs/*.jar

# Allow the legal files that the image now publishes into /usr/share/doc/gridgrind.
!LICENSE
!NOTICE
!PATENTS.md
!LICENSE-APACHE-2.0
!LICENSE-BSD-3-CLAUSE
