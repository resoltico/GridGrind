#!/usr/bin/env bash

# Shared repo-verification lock adapter for Jazzer launcher scripts. Expects the caller to define:
#   lock_dir
#   pid_file

run_lock_script_dir="$(cd -P -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
run_lock_repo_root="$(cd -P -- "${run_lock_script_dir}/../.." && pwd)"
repo_lock_support="${run_lock_repo_root}/scripts/repo-verification-lock-support.sh"

# shellcheck source=/dev/null
source "${repo_lock_support}"
