{
  "protocolVersion": "V1",
  "source": { "type": "NEW" },
  "persistence": {
    "type": "SAVE_AS",
    "path": "cli/build/generated-workbooks/gridgrind-data-validation-request.xlsx"
  },
  "operations": [
    { "type": "ENSURE_SHEET", "sheetName": "Intake" },
    {
      "type": "SET_RANGE",
      "sheetName": "Intake",
      "range": "A1:E4",
      "rows": [
        [
          { "type": "TEXT", "text": "Ticket" },
          { "type": "TEXT", "text": "Status" },
          { "type": "TEXT", "text": "Priority" },
          { "type": "TEXT", "text": "ETA" },
          { "type": "TEXT", "text": "Notes" }
        ],
        [
          { "type": "TEXT", "text": "OPS-102" },
          { "type": "TEXT", "text": "Queued" },
          { "type": "NUMBER", "number": 2 },
          { "type": "DATE", "date": "2026-04-03" },
          { "type": "TEXT", "text": "Intake ready" }
        ],
        [
          { "type": "TEXT", "text": "OPS-103" },
          { "type": "TEXT", "text": "Done" },
          { "type": "NUMBER", "number": 4 },
          { "type": "DATE", "date": "2026-04-05" },
          { "type": "TEXT", "text": "Awaiting sign-off" }
        ],
        [
          { "type": "TEXT", "text": "OPS-104" },
          { "type": "TEXT", "text": "Blocked" },
          { "type": "NUMBER", "number": 5 },
          { "type": "DATE", "date": "2026-04-08" },
          { "type": "TEXT", "text": "Dependency gap" }
        ]
      ]
    },
    {
      "type": "SET_DATA_VALIDATION",
      "sheetName": "Intake",
      "range": "B2:B200",
      "validation": {
        "rule": {
          "type": "EXPLICIT_LIST",
          "values": ["Queued", "Done", "Blocked"]
        },
        "allowBlank": true,
        "prompt": {
          "title": "Status",
          "text": "Pick one workflow state."
        },
        "errorAlert": {
          "style": "STOP",
          "title": "Invalid status",
          "text": "Use one of the allowed values."
        }
      }
    },
    {
      "type": "SET_DATA_VALIDATION",
      "sheetName": "Intake",
      "range": "C2:C200",
      "validation": {
        "rule": {
          "type": "WHOLE_NUMBER",
          "operator": "BETWEEN",
          "formula1": "1",
          "formula2": "5"
        }
      }
    },
    {
      "type": "CLEAR_DATA_VALIDATIONS",
      "sheetName": "Intake",
      "selection": {
        "type": "SELECTED",
        "ranges": ["B3", "C4"]
      }
    },
    {
      "type": "SET_DATA_VALIDATION",
      "sheetName": "Intake",
      "range": "D2:D200",
      "validation": {
        "rule": {
          "type": "DATE",
          "operator": "GREATER_OR_EQUAL",
          "formula1": "TODAY()"
        }
      }
    }
  ],
  "reads": [
    {
      "type": "GET_DATA_VALIDATIONS",
      "requestId": "validations",
      "sheetName": "Intake",
      "selection": { "type": "ALL" }
    },
    {
      "type": "ANALYZE_DATA_VALIDATION_HEALTH",
      "requestId": "validation-health",
      "selection": {
        "type": "SELECTED",
        "sheetNames": ["Intake"]
      }
    },
    {
      "type": "GET_CELLS",
      "requestId": "cells",
      "sheetName": "Intake",
      "addresses": ["B2", "C3", "D4"]
    }
  ]
}
