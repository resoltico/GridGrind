{
  "protocolVersion": "V1",
  "source": { "type": "NEW" },
  "persistence": {
    "type": "SAVE_AS",
    "path": "cli/build/generated-workbooks/gridgrind-rich-text.xlsx"
  },
  "operations": [
    { "type": "ENSURE_SHEET", "sheetName": "Narrative" },
    {
      "type": "APPLY_STYLE",
      "sheetName": "Narrative",
      "range": "A1:A2",
      "style": {
        "alignment": {
          "wrapText": true,
          "verticalAlignment": "CENTER"
        },
        "font": {
          "fontName": "Aptos",
          "fontHeight": { "type": "POINTS", "points": 12 },
          "fontColor": "#1F1F1F"
        }
      }
    },
    {
      "type": "SET_CELL",
      "sheetName": "Narrative",
      "address": "A1",
      "value": {
        "type": "RICH_TEXT",
        "runs": [
          {
            "text": "Q2 ",
            "font": {
              "fontColor": "#44546A"
            }
          },
          {
            "text": "Budget",
            "font": {
              "bold": true,
              "fontColor": "#C00000"
            }
          },
          {
            "text": " Review",
            "font": {
              "italic": true,
              "underline": true
            }
          }
        ]
      }
    },
    {
      "type": "SET_CELL",
      "sheetName": "Narrative",
      "address": "A2",
      "value": { "type": "TEXT", "text": "Plain text stays plain." }
    }
  ],
  "reads": [
    {
      "type": "GET_CELLS",
      "requestId": "cells",
      "sheetName": "Narrative",
      "addresses": ["A1", "A2"]
    },
    {
      "type": "GET_WINDOW",
      "requestId": "window",
      "sheetName": "Narrative",
      "topLeftAddress": "A1",
      "rowCount": 2,
      "columnCount": 1
    }
  ]
}
