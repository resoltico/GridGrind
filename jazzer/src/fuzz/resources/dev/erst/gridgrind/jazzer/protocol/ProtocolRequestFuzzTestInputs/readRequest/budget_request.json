{
  "protocolVersion": "V1",
  "source": { "mode": "NEW" },
  "persistence": {
    "mode": "SAVE_AS",
    "path": "cli/build/generated-workbooks/gridgrind-budget.xlsx"
  },
  "operations": [
    { "type": "ENSURE_SHEET", "sheetName": "Budget" },
    {
      "type": "SET_RANGE",
      "sheetName": "Budget",
      "range": "A1:C3",
      "rows": [
        [
          { "type": "TEXT", "text": "Item" },
          { "type": "TEXT", "text": "Amount" },
          { "type": "TEXT", "text": "Billable" }
        ],
        [
          { "type": "TEXT", "text": "Hosting" },
          { "type": "NUMBER", "number": 49.0 },
          { "type": "BOOLEAN", "bool": true }
        ],
        [
          { "type": "TEXT", "text": "Domain" },
          { "type": "NUMBER", "number": 12.0 },
          { "type": "BOOLEAN", "bool": false }
        ]
      ]
    },
    {
      "type": "APPLY_STYLE",
      "sheetName": "Budget",
      "range": "A1:C1",
      "style": {
        "bold": true,
        "wrapText": true,
        "horizontalAlignment": "CENTER",
        "verticalAlignment": "CENTER"
      }
    },
    {
      "type": "APPLY_STYLE",
      "sheetName": "Budget",
      "range": "B2:B4",
      "style": {
        "numberFormat": "#,##0.00",
        "horizontalAlignment": "RIGHT"
      }
    },
    {
      "type": "SET_CELL",
      "sheetName": "Budget",
      "address": "A4",
      "value": { "type": "TEXT", "text": "Total" }
    },
    {
      "type": "SET_CELL",
      "sheetName": "Budget",
      "address": "B4",
      "value": { "type": "FORMULA", "formula": "SUM(B2:B3)" }
    },
    { "type": "AUTO_SIZE_COLUMNS", "sheetName": "Budget" },
    { "type": "EVALUATE_FORMULAS" },
    { "type": "FORCE_FORMULA_RECALCULATION_ON_OPEN" }
  ],
  "reads": [
    { "type": "GET_WORKBOOK_SUMMARY", "requestId": "workbook" },
    {
      "type": "GET_CELLS",
      "requestId": "cells",
      "sheetName": "Budget",
      "addresses": ["A1", "B4", "C2"]
    },
    {
      "type": "GET_WINDOW",
      "requestId": "window",
      "sheetName": "Budget",
      "topLeftAddress": "A1",
      "rowCount": 4,
      "columnCount": 3
    },
    {
      "type": "ANALYZE_FORMULA_SURFACE",
      "requestId": "formula-surface",
      "selection": {
        "mode": "SELECTED",
        "sheetNames": ["Budget"]
      }
    },
    {
      "type": "ANALYZE_SHEET_SCHEMA",
      "requestId": "schema",
      "sheetName": "Budget",
      "topLeftAddress": "A1",
      "rowCount": 4,
      "columnCount": 3
    }
  ]
}
