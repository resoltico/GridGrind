{
  "protocolVersion": "V1",
  "planId": "chart-workflow",
  "source": {
    "type": "NEW"
  },
  "persistence": {
    "type": "SAVE_AS",
    "path": "cli/build/generated-workbooks/gridgrind-chart.xlsx"
  },
  "steps": [
    {
      "stepId": "step-01-ensure-sheet",
      "target": {
        "type": "SHEET_BY_NAME",
        "name": "Ops"
      },
      "action": {
        "type": "ENSURE_SHEET"
      }
    },
    {
      "stepId": "step-02-set-range",
      "target": {
        "type": "RANGE_BY_RANGE",
        "sheetName": "Ops",
        "range": "A1:C4"
      },
      "action": {
        "type": "SET_RANGE",
        "rows": [
          [
            {
              "type": "TEXT",
              "source": {
                "type": "INLINE",
                "text": "Month"
              }
            },
            {
              "type": "TEXT",
              "source": {
                "type": "INLINE",
                "text": "Plan"
              }
            },
            {
              "type": "TEXT",
              "source": {
                "type": "INLINE",
                "text": "Actual"
              }
            }
          ],
          [
            {
              "type": "TEXT",
              "source": {
                "type": "INLINE",
                "text": "Jan"
              }
            },
            {
              "type": "NUMBER",
              "number": 10.0
            },
            {
              "type": "NUMBER",
              "number": 12.0
            }
          ],
          [
            {
              "type": "TEXT",
              "source": {
                "type": "INLINE",
                "text": "Feb"
              }
            },
            {
              "type": "NUMBER",
              "number": 18.0
            },
            {
              "type": "NUMBER",
              "number": 17.0
            }
          ],
          [
            {
              "type": "TEXT",
              "source": {
                "type": "INLINE",
                "text": "Mar"
              }
            },
            {
              "type": "NUMBER",
              "number": 15.0
            },
            {
              "type": "NUMBER",
              "number": 16.0
            }
          ]
        ]
      }
    },
    {
      "stepId": "step-03-set-categories",
      "target": {
        "type": "NAMED_RANGE_WORKBOOK_SCOPE",
        "name": "ChartCategories"
      },
      "action": {
        "type": "SET_NAMED_RANGE",
        "name": "ChartCategories",
        "scope": {
          "type": "WORKBOOK"
        },
        "target": {
          "sheetName": "Ops",
          "range": "A2:A4"
        }
      }
    },
    {
      "stepId": "step-04-set-actual",
      "target": {
        "type": "NAMED_RANGE_WORKBOOK_SCOPE",
        "name": "ChartActual"
      },
      "action": {
        "type": "SET_NAMED_RANGE",
        "name": "ChartActual",
        "scope": {
          "type": "WORKBOOK"
        },
        "target": {
          "sheetName": "Ops",
          "range": "C2:C4"
        }
      }
    },
    {
      "stepId": "step-05-set-chart",
      "target": {
        "type": "SHEET_BY_NAME",
        "name": "Ops"
      },
      "action": {
        "type": "SET_CHART",
        "chart": {
          "name": "OpsChart",
          "anchor": {
            "type": "TWO_CELL",
            "from": {
              "columnIndex": 4,
              "rowIndex": 0,
              "dx": 0,
              "dy": 0
            },
            "to": {
              "columnIndex": 8,
              "rowIndex": 12,
              "dx": 0,
              "dy": 0
            },
            "behavior": "MOVE_AND_RESIZE"
          },
          "title": {
            "type": "TEXT",
            "source": {
              "type": "INLINE",
              "text": "Roadmap"
            }
          },
          "legend": {
            "type": "VISIBLE",
            "position": "TOP_RIGHT"
          },
          "displayBlanksAs": "SPAN",
          "plotOnlyVisibleCells": false,
          "plots": [
            {
              "type": "BAR",
              "varyColors": true,
              "barDirection": "COLUMN",
              "grouping": "CLUSTERED",
              "axes": [
                {
                  "kind": "CATEGORY",
                  "position": "BOTTOM",
                  "crosses": "AUTO_ZERO",
                  "visible": true
                },
                {
                  "kind": "VALUE",
                  "position": "LEFT",
                  "crosses": "AUTO_ZERO",
                  "visible": true
                }
              ],
              "series": [
                {
                  "title": {
                    "type": "TEXT",
                    "source": {
                      "type": "INLINE",
                      "text": "Plan"
                    }
                  },
                  "categories": {
                    "type": "REFERENCE",
                    "formula": "ChartCategories"
                  },
                  "values": {
                    "type": "REFERENCE",
                    "formula": "Ops!$B$2:$B$4"
                  }
                },
                {
                  "title": {
                    "type": "TEXT",
                    "source": {
                      "type": "INLINE",
                      "text": "Actual"
                    }
                  },
                  "categories": {
                    "type": "REFERENCE",
                    "formula": "ChartCategories"
                  },
                  "values": {
                    "type": "REFERENCE",
                    "formula": "ChartActual"
                  }
                }
              ]
            }
          ]
        }
      }
    },
    {
      "stepId": "charts",
      "target": {
        "type": "SHEET_BY_NAME",
        "name": "Ops"
      },
      "query": {
        "type": "GET_CHARTS"
      }
    },
    {
      "stepId": "chart-present",
      "target": {
        "type": "CHART_BY_NAME",
        "sheetName": "Ops",
        "chartName": "OpsChart"
      },
      "assertion": {
        "type": "EXPECT_CHART_PRESENT"
      }
    }
  ]
}
