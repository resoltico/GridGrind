{
  "protocolVersion": "V1",
  "source": { "type": "NEW" },
  "persistence": {
    "type": "SAVE_AS",
    "path": "cli/build/generated-workbooks/gridgrind-excel-authoring-essentials.xlsx"
  },
  "operations": [
    { "type": "ENSURE_SHEET", "sheetName": "Budget" },
    {
      "type": "SET_RANGE",
      "sheetName": "Budget",
      "range": "A1:B4",
      "rows": [
        [
          { "type": "TEXT", "text": "Label" },
          { "type": "TEXT", "text": "Value" }
        ],
        [
          { "type": "TEXT", "text": "Hosting" },
          { "type": "NUMBER", "number": 49.0 }
        ],
        [
          { "type": "TEXT", "text": "Domain" },
          { "type": "NUMBER", "number": 12.0 }
        ],
        [
          { "type": "TEXT", "text": "Total" },
          { "type": "FORMULA", "formula": "SUM(B2:B3)" }
        ]
      ]
    },
    {
      "type": "SET_HYPERLINK",
      "sheetName": "Budget",
      "address": "A1",
      "target": {
        "type": "URL",
        "target": "https://example.com/budget-handbook"
      }
    },
    {
      "type": "SET_COMMENT",
      "sheetName": "Budget",
      "address": "B4",
      "comment": {
        "text": "Verified by finance on 2026-03-26.",
        "author": "GridGrind",
        "visible": true
      }
    },
    {
      "type": "SET_NAMED_RANGE",
      "name": "BudgetTotal",
      "scope": { "type": "WORKBOOK" },
      "target": { "sheetName": "Budget", "range": "B4" }
    },
    {
      "type": "SET_NAMED_RANGE",
      "name": "BudgetTable",
      "scope": { "type": "SHEET", "sheetName": "Budget" },
      "target": { "sheetName": "Budget", "range": "A1:B4" }
    },
    { "type": "EVALUATE_FORMULAS" }
  ],
  "reads": [
    {
      "type": "GET_CELLS",
      "requestId": "cells",
      "sheetName": "Budget",
      "addresses": ["A1", "B4"]
    },
    {
      "type": "GET_WINDOW",
      "requestId": "window",
      "sheetName": "Budget",
      "topLeftAddress": "A1",
      "rowCount": 4,
      "columnCount": 2
    },
    {
      "type": "GET_HYPERLINKS",
      "requestId": "hyperlinks",
      "sheetName": "Budget",
      "selection": {
        "type": "SELECTED",
        "addresses": ["A1", "B4"]
      }
    },
    {
      "type": "GET_COMMENTS",
      "requestId": "comments",
      "sheetName": "Budget",
      "selection": {
        "type": "SELECTED",
        "addresses": ["A1", "B4"]
      }
    },
    {
      "type": "GET_NAMED_RANGES",
      "requestId": "named-ranges",
      "selection": { "type": "ALL" }
    },
    {
      "type": "GET_NAMED_RANGE_SURFACE",
      "requestId": "named-range-surface",
      "selection": { "type": "ALL" }
    }
  ]
}
