<?xml version="1.0" encoding="UTF-8"?>
<ruleset
    name="GridGrind Java Quality"
    xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/pmd-7.0.0/ruleset_xml_schema.xsd">
    <description>
        High-signal PMD rules for GridGrind Java code. Formatting is enforced by Spotless,
        compiler-grade correctness by Error Prone, and PMD covers structural, best-practice,
        design, performance, security, and concurrency issues.
    </description>

    <rule ref="category/java/errorprone.xml">
        <exclude name="AvoidCatchingGenericException"/>
        <exclude name="AvoidDuplicateLiterals"/>
        <exclude name="AvoidFieldNameMatchingMethodName"/>
        <exclude name="AvoidLiteralsInIfCondition"/>
        <exclude name="NullAssignment"/>
    </rule>

    <rule ref="category/java/bestpractices.xml"/>

    <rule ref="category/java/design.xml">
        <!-- Demeter violations are too noisy for a layered facade API -->
        <exclude name="LawOfDemeter"/>
        <!-- Requires explicit package configurations to be useful -->
        <exclude name="LoosePackageCoupling"/>
        <!-- Produces false positives on well-structured value/command objects -->
        <exclude name="DataClass"/>
    </rule>

    <rule ref="category/java/multithreading.xml"/>

    <rule ref="category/java/performance.xml"/>

    <rule ref="category/java/security.xml"/>

    <rule ref="category/java/documentation.xml/CommentRequired">
        <properties>
            <property name="classCommentRequirement" value="Required"/>
            <property name="enumCommentRequirement" value="Required"/>
            <property name="publicMethodCommentRequirement" value="Required"/>
            <property name="methodWithOverrideCommentRequirement" value="Ignored"/>
            <property name="accessorCommentRequirement" value="Ignored"/>
            <property name="fieldCommentRequirement" value="Ignored"/>
            <property name="protectedMethodCommentRequirement" value="Ignored"/>
            <property name="serialVersionUIDCommentRequirement" value="Ignored"/>
            <property name="serialPersistentFieldsCommentRequirement" value="Ignored"/>
        </properties>
    </rule>

    <rule ref="category/java/documentation.xml/UncommentedEmptyMethodBody"/>

</ruleset>
