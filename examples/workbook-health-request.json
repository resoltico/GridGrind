{
  "protocolVersion" : "V1",
  "planId" : "workbook-health-workflow",
  "source" : {
    "type" : "NEW"
  },
  "persistence" : {
    "type" : "NONE"
  },
  "steps" : [ {
    "stepId" : "step-01-ensure-budget-review",
    "target" : {
      "type" : "SHEET_BY_NAME",
      "name" : "Budget Review"
    },
    "action" : {
      "type" : "ENSURE_SHEET"
    }
  }, {
    "stepId" : "step-02-ensure-summary",
    "target" : {
      "type" : "SHEET_BY_NAME",
      "name" : "Summary"
    },
    "action" : {
      "type" : "ENSURE_SHEET"
    }
  }, {
    "stepId" : "step-03-set-budget-header",
    "target" : {
      "type" : "CELL_BY_ADDRESS",
      "sheetName" : "Budget Review",
      "address" : "A1"
    },
    "action" : {
      "type" : "SET_CELL",
      "value" : {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Amount"
        }
      }
    }
  }, {
    "stepId" : "step-04-set-budget-value",
    "target" : {
      "type" : "CELL_BY_ADDRESS",
      "sheetName" : "Budget Review",
      "address" : "B1"
    },
    "action" : {
      "type" : "SET_CELL",
      "value" : {
        "type" : "NUMBER",
        "number" : 1200.0
      }
    }
  }, {
    "stepId" : "step-05-set-summary-formula",
    "target" : {
      "type" : "CELL_BY_ADDRESS",
      "sheetName" : "Summary",
      "address" : "A1"
    },
    "action" : {
      "type" : "SET_CELL",
      "value" : {
        "type" : "FORMULA",
        "source" : {
          "type" : "INLINE",
          "text" : "'Budget Review'!B1"
        }
      }
    }
  }, {
    "stepId" : "summary-sheet",
    "target" : {
      "type" : "SHEET_BY_NAME",
      "name" : "Summary"
    },
    "query" : {
      "type" : "GET_SHEET_SUMMARY"
    }
  }, {
    "stepId" : "formula-health",
    "target" : {
      "type" : "SHEET_BY_NAMES",
      "names" : [ "Summary" ]
    },
    "query" : {
      "type" : "ANALYZE_FORMULA_HEALTH"
    }
  }, {
    "stepId" : "lint",
    "target" : {
      "type" : "WORKBOOK_CURRENT"
    },
    "query" : {
      "type" : "ANALYZE_WORKBOOK_FINDINGS"
    }
  }, {
    "stepId" : "summary-cells",
    "target" : {
      "type" : "CELL_BY_ADDRESSES",
      "sheetName" : "Summary",
      "addresses" : [ "A1" ]
    },
    "query" : {
      "type" : "GET_CELLS"
    }
  } ]
}
