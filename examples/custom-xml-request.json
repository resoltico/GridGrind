{
  "protocolVersion" : "V1",
  "planId" : "custom-xml-workflow",
  "source" : {
    "type" : "EXISTING",
    "path" : "examples/custom-xml-assets/custom-xml-mapping.xlsx"
  },
  "persistence" : {
    "type" : "NONE"
  },
  "steps" : [ {
    "stepId" : "read-custom-xml-mappings",
    "target" : {
      "type" : "CURRENT"
    },
    "query" : {
      "type" : "GET_CUSTOM_XML_MAPPINGS"
    }
  }, {
    "stepId" : "export-custom-xml-before-import",
    "target" : {
      "type" : "CURRENT"
    },
    "query" : {
      "type" : "EXPORT_CUSTOM_XML_MAPPING",
      "mapping" : {
        "mapId" : 1,
        "name" : "CORSO_mapping"
      },
      "validateSchema" : true,
      "encoding" : "UTF-8"
    }
  }, {
    "stepId" : "import-custom-xml",
    "target" : {
      "type" : "CURRENT"
    },
    "action" : {
      "type" : "IMPORT_CUSTOM_XML_MAPPING",
      "mapping" : {
        "locator" : {
          "mapId" : 1,
          "name" : "CORSO_mapping"
        },
        "xml" : {
          "type" : "UTF8_FILE",
          "path" : "examples/custom-xml-assets/custom-xml-update.xml"
        }
      }
    }
  }, {
    "stepId" : "read-imported-cells",
    "target" : {
      "type" : "BY_ADDRESSES",
      "sheetName" : "Foglio1",
      "addresses" : [ "A1", "B1", "C1", "D1" ]
    },
    "query" : {
      "type" : "GET_CELLS"
    }
  }, {
    "stepId" : "export-custom-xml-after-import",
    "target" : {
      "type" : "CURRENT"
    },
    "query" : {
      "type" : "EXPORT_CUSTOM_XML_MAPPING",
      "mapping" : {
        "mapId" : 1,
        "name" : "CORSO_mapping"
      },
      "validateSchema" : true,
      "encoding" : "UTF-8"
    }
  } ]
}
