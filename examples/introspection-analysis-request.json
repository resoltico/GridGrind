{
  "protocolVersion" : "V1",
  "planId" : "introspection-analysis-workflow",
  "source" : {
    "type" : "NEW"
  },
  "persistence" : {
    "type" : "SAVE_AS",
    "path" : "../cli/build/generated-workbooks/gridgrind-introspection-analysis.xlsx"
  },
  "steps" : [ {
    "stepId" : "step-01-ensure-sheet",
    "target" : {
      "type" : "SHEET_BY_NAME",
      "name" : "Dashboard"
    },
    "action" : {
      "type" : "ENSURE_SHEET"
    }
  }, {
    "stepId" : "step-02-set-range",
    "target" : {
      "type" : "RANGE_BY_RANGE",
      "sheetName" : "Dashboard",
      "range" : "A1:C4"
    },
    "action" : {
      "type" : "SET_RANGE",
      "rows" : [ [ {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Metric"
        }
      }, {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Value"
        }
      }, {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Notes"
        }
      } ], [ {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Revenue"
        }
      }, {
        "type" : "NUMBER",
        "number" : 125000.25
      }, {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Closed month"
        }
      } ], [ {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Margin"
        }
      }, {
        "type" : "NUMBER",
        "number" : 0.42
      }, {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Target 0.40"
        }
      } ], [ {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Forecast"
        }
      }, {
        "type" : "FORMULA",
        "source" : {
          "type" : "INLINE",
          "text" : "B2*(1+B3)"
        }
      }, {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Projected next month"
        }
      } ] ]
    }
  }, {
    "stepId" : "step-03-set-hyperlink",
    "target" : {
      "type" : "CELL_BY_ADDRESS",
      "sheetName" : "Dashboard",
      "address" : "A1"
    },
    "action" : {
      "type" : "SET_HYPERLINK",
      "target" : {
        "type" : "URL",
        "target" : "https://example.com/dashboard-handbook"
      }
    }
  }, {
    "stepId" : "step-04-set-comment",
    "target" : {
      "type" : "CELL_BY_ADDRESS",
      "sheetName" : "Dashboard",
      "address" : "B4"
    },
    "action" : {
      "type" : "SET_COMMENT",
      "comment" : {
        "text" : {
          "type" : "INLINE",
          "text" : "Forecast uses the revenue and margin rows above."
        },
        "author" : "GridGrind",
        "visible" : true
      }
    }
  }, {
    "stepId" : "step-05-set-named-range",
    "target" : {
      "type" : "NAMED_RANGE_WORKBOOK_SCOPE",
      "name" : "ForecastValue"
    },
    "action" : {
      "type" : "SET_NAMED_RANGE",
      "name" : "ForecastValue",
      "scope" : {
        "type" : "WORKBOOK"
      },
      "target" : {
        "sheetName" : "Dashboard",
        "range" : "B4"
      }
    }
  }, {
    "stepId" : "workbook",
    "target" : {
      "type" : "WORKBOOK_CURRENT"
    },
    "query" : {
      "type" : "GET_WORKBOOK_SUMMARY"
    }
  }, {
    "stepId" : "formula-surface",
    "target" : {
      "type" : "SHEET_BY_NAMES",
      "names" : [ "Dashboard" ]
    },
    "query" : {
      "type" : "GET_FORMULA_SURFACE"
    }
  }, {
    "stepId" : "schema",
    "target" : {
      "type" : "RANGE_RECTANGULAR_WINDOW",
      "sheetName" : "Dashboard",
      "topLeftAddress" : "A1",
      "rowCount" : 4,
      "columnCount" : 3
    },
    "query" : {
      "type" : "GET_SHEET_SCHEMA"
    }
  }, {
    "stepId" : "named-range-surface",
    "target" : {
      "type" : "NAMED_RANGE_BY_NAME",
      "name" : "ForecastValue"
    },
    "query" : {
      "type" : "GET_NAMED_RANGE_SURFACE"
    }
  }, {
    "stepId" : "formula-health",
    "target" : {
      "type" : "SHEET_BY_NAMES",
      "names" : [ "Dashboard" ]
    },
    "query" : {
      "type" : "ANALYZE_FORMULA_HEALTH"
    }
  }, {
    "stepId" : "hyperlink-health",
    "target" : {
      "type" : "SHEET_BY_NAMES",
      "names" : [ "Dashboard" ]
    },
    "query" : {
      "type" : "ANALYZE_HYPERLINK_HEALTH"
    }
  }, {
    "stepId" : "named-range-health",
    "target" : {
      "type" : "NAMED_RANGE_BY_NAME",
      "name" : "ForecastValue"
    },
    "query" : {
      "type" : "ANALYZE_NAMED_RANGE_HEALTH"
    }
  }, {
    "stepId" : "workbook-findings",
    "target" : {
      "type" : "WORKBOOK_CURRENT"
    },
    "query" : {
      "type" : "ANALYZE_WORKBOOK_FINDINGS"
    }
  } ]
}
