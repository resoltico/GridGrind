{
  "protocolVersion" : "V1",
  "planId" : "file-hyperlink-health-workflow",
  "source" : {
    "type" : "NEW"
  },
  "persistence" : {
    "type" : "SAVE_AS",
    "path" : "generated-workbooks/gridgrind-file-hyperlink-health.xlsx"
  },
  "execution" : {
    "mode" : {
      "readMode" : "FULL_XSSF",
      "writeMode" : "FULL_XSSF"
    },
    "journal" : {
      "level" : "NORMAL"
    },
    "calculation" : {
      "strategy" : {
        "type" : "DO_NOT_CALCULATE"
      },
      "markRecalculateOnOpen" : false
    }
  },
  "formulaEnvironment" : {
    "externalWorkbooks" : [ ],
    "missingWorkbookPolicy" : "ERROR",
    "udfToolpacks" : [ ]
  },
  "steps" : [ {
    "stepId" : "step-01-ensure-sheet",
    "target" : {
      "type" : "SHEET_BY_NAME",
      "name" : "Links"
    },
    "action" : {
      "type" : "ENSURE_SHEET"
    }
  }, {
    "stepId" : "step-02-set-range",
    "target" : {
      "type" : "RANGE_BY_RANGE",
      "sheetName" : "Links",
      "range" : "A1:B4"
    },
    "action" : {
      "type" : "SET_RANGE",
      "rows" : [ [ {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Label"
        }
      }, {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Destination"
        }
      } ], [ {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Relative policy PDF"
        }
      }, {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "support/expense policy 2026.pdf"
        }
      } ], [ {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Absolute checklist URI"
        }
      }, {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "file:///tmp/quarterly%20close/checklist.xlsx"
        }
      } ], [ {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Workbook section"
        }
      }, {
        "type" : "TEXT",
        "source" : {
          "type" : "INLINE",
          "text" : "Links!B2"
        }
      } ] ]
    }
  }, {
    "stepId" : "step-03-relative-file-link",
    "target" : {
      "type" : "CELL_BY_ADDRESS",
      "sheetName" : "Links",
      "address" : "A2"
    },
    "action" : {
      "type" : "SET_HYPERLINK",
      "target" : {
        "type" : "FILE",
        "path" : "support/expense policy 2026.pdf"
      }
    }
  }, {
    "stepId" : "step-04-absolute-file-link",
    "target" : {
      "type" : "CELL_BY_ADDRESS",
      "sheetName" : "Links",
      "address" : "A3"
    },
    "action" : {
      "type" : "SET_HYPERLINK",
      "target" : {
        "type" : "FILE",
        "path" : "/tmp/quarterly close/checklist.xlsx"
      }
    }
  }, {
    "stepId" : "step-05-document-link",
    "target" : {
      "type" : "CELL_BY_ADDRESS",
      "sheetName" : "Links",
      "address" : "A4"
    },
    "action" : {
      "type" : "SET_HYPERLINK",
      "target" : {
        "type" : "DOCUMENT",
        "target" : "Links!B2"
      }
    }
  }, {
    "stepId" : "hyperlinks",
    "target" : {
      "type" : "CELL_BY_ADDRESSES",
      "sheetName" : "Links",
      "addresses" : [ "A2", "A3", "A4" ]
    },
    "query" : {
      "type" : "GET_HYPERLINKS"
    }
  }, {
    "stepId" : "hyperlink-health",
    "target" : {
      "type" : "SHEET_BY_NAMES",
      "names" : [ "Links" ]
    },
    "query" : {
      "type" : "ANALYZE_HYPERLINK_HEALTH"
    }
  } ]
}
